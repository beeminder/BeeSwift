# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

TEAM_ID = "8TW9V9HVES"
APP_IDENTIFIER = "com.beeminder.beeminder"
ASC_KEY_DURATION = 1200

platform :ios do
  lane :test do
    run_tests(
        scheme: "BeeSwift",
        reset_simulator: true,
    )
  end
  lane :ci do
    sh("xcrun simctl list devices")
    sleep 1
    
    sh("xcrun simctl delete all")
    sleep 5
    
    sh("xcrun simctl list devicetypes")
    sh("xcrun simctl list runtimes")
    
    sh("xcrun simctl create Test-iPhone com.apple.CoreSimulator.SimDeviceType.iPhone-17-Pro com.apple.CoreSimulator.SimRuntime.iOS-26-1")
    sleep 5
    sh("xcrun simctl list devices")

    run_tests(
        scheme: "BeeSwift",
        destination: "platform=iOS Simulator,name=Test-iPhone,OS=26.1",
        prelaunch_simulator: true,
        reset_simulator: true,
        include_simulator_logs: true,
        buildlog_path: "fastlane/test_output",
        ensure_devices_found: true,
        cloned_source_packages_path: "SPMCache",
        xcodebuild_formatter: "xcbeautify --renderer github-actions",
    )
  end
  lane :build do
    build_app(scheme: "BeeSwift")
  end
  lane :beta do
    # Ensure that your git status is not dirty
    ensure_git_status_clean

    app_store_connect_api_key(
      key_id: "DL3L84F9JY",
      issuer_id: "69a6de78-3567-47e3-e053-5b8c7c11a4d1",
      key_filepath: "fastlane/AuthKey_DL3L84F9JY.p8",
      duration: ASC_KEY_DURATION,
      in_house: false
    )


    # Increment the build number (not the version number)
    # Providing the xcodeproj is optional
    increment_build_number(
      build_number: latest_testflight_build_number + 1,
      xcodeproj: "BeeSwift.xcodeproj"
    )
    
    build_app(scheme: "BeeSwift")

    upload_to_testflight

    # Add a git tag for this build. This will automatically
    # use an appropriate git tag name
    # Note this tag will not include the uncommited version changes
    add_git_tag

    # Push the tag to github
    push_git_tags

    reset_git_repo(
      skip_clean: true,
      files: [
        "BeeSwift.xcodeproj",
        "*/Info.plist"
      ]
    )
  end
  # Unattended TestFlight build for CI. Signing assets come from `match`
  # (git storage repo, accessed over SSH); App Store Connect credentials and
  # the match passphrase are supplied via environment variables.
  lane :beta_ci do
    # Create a temporary, unlocked keychain so codesign can use the match
    # signing identity without an interactive keychain-access prompt, which
    # would otherwise hang the archive indefinitely on a headless CI runner.
    setup_ci

    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_P8_BASE64"),
      is_key_content_base64: true,
      duration: ASC_KEY_DURATION,
      in_house: false
    )

    match(
      type: "appstore",
      readonly: false
    )

    increment_build_number(
      build_number: latest_testflight_build_number + 1,
      xcodeproj: "BeeSwift.xcodeproj"
    )

    # The project uses automatic signing for local development; flip the
    # targets that get archived to manual signing for CI. The app target uses
    # the match-managed distribution profile; the embedded BeeKit framework is
    # signed with the distribution identity but needs no provisioning profile.
    profile_name = ENV.fetch("sigh_#{APP_IDENTIFIER}_appstore_profile-name")
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "BeeSwift.xcodeproj",
      targets: ["BeeSwift"],
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution",
      bundle_identifier: APP_IDENTIFIER,
      profile_name: profile_name
    )
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "BeeSwift.xcodeproj",
      targets: ["BeeKit"],
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution"
    )

    build_app(
      scheme: "BeeSwift",
      export_method: "app-store",
      buildlog_path: "fastlane/build_output",
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => profile_name
        }
      }
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )

    add_git_tag
    push_git_tags
  end
  lane :increment_major_version do
    increment_version_number(
      bump_type: "major",
      xcodeproj: "BeeSwift.xcodeproj"
    )
  end
  lane :increment_minor_version do
    increment_version_number(
      bump_type: "minor",
      xcodeproj: "BeeSwift.xcodeproj"
    )
  end

  lane :format do
    Dir.chdir("..") do
      sh("swift-format", "--recursive", "--in-place", ".")
    end
  end
end
